# Optional: enables LLM-based extraction. Without LLM_API_KEY, the agent falls back to regex extraction.
# Works with any OpenAI-compatible provider (Groq, xAI, OpenAI, ...).
# Defaults target Groq's free tier: https://console.groq.com
LLM_API_KEY=
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile
